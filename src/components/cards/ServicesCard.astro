---
import { config, t } from '../../utils/config';

export interface Props {
  lang: string;
  index: number;
  total: number;
  viewport: 'mobile' | 'desktop';
}

const { lang, viewport } = Astro.props;

const ui = {
  heading: {
    de: 'Behandlungen',
    fr: 'Services',
    it: 'Servizi',
    en: 'Services',
  } as Record<string, string>,
  subtitle: {
    de: 'Wir nehmen uns Zeit für Sie.',
    fr: `Depuis ${config.business.founded} · ${config.location.city}`,
    it: `Dal ${config.business.founded} · ${config.location.city}`,
    en: `Since ${config.business.founded} · ${config.location.city}`,
  } as Record<string, string>,
};

const count = config.services.length;
const grid =
  count <= 2 ? 'md:grid-cols-2' : count === 3 ? 'md:grid-cols-3' : 'md:grid-cols-4';
---

{viewport === 'mobile' ? (
  <section class="min-h-[100dvh] w-full px-6 py-12 flex items-center justify-center">
    <div class="w-full max-w-sm">
      <div class="text-center">
        <h2 class="text-2xl font-semibold tracking-tight" data-animate>
          {ui.heading[lang] ?? ui.heading.en}
        </h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-white/60" data-animate>
          {ui.subtitle[lang] ?? ui.subtitle.en}
        </p>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-3" data-animate>
        {config.services.map((s) => (
          <article class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-4 text-left">
            <h3 class="text-sm font-semibold">{t(s.title, lang)}</h3>
            <p class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-white/70">
              {t(s.description, lang)}
            </p>
          </article>
        ))}
      </div>

      <div class="mt-8 text-center" data-animate>
        <a
          href="/leistungen"
          class="inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold bg-white hover:bg-slate-50 text-slate-900 border border-black/10 hover:border-black/20 transition-all duration-300 dark:bg-white/10 dark:text-white dark:hover:bg-white/15 dark:border-white/10 dark:hover:border-white/20"
        >
          Alle Behandlungen ansehen
          <i data-lucide="arrow-right" class="ml-2 h-4 w-4" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </section>
) : (
  <section class="w-full py-20">
    <div class="mx-auto max-w-6xl px-8 text-center">
      <h2 class="text-4xl font-semibold tracking-tight" data-animate>
        {ui.heading[lang] ?? ui.heading.en}
      </h2>
      <p class="mt-3 text-slate-600 dark:text-white/60" data-animate>
        {ui.subtitle[lang] ?? ui.subtitle.en}
      </p>

      <div class={`mt-12 grid grid-cols-1 gap-6 ${grid}`}>
        {config.services.map((s, i) => (
          <article
            class="group rounded-2xl bg-white border border-black/10 dark:bg-white/6 dark:border-white/10 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:bg-slate-50 hover:border-black/20 dark:hover:bg-white/10 dark:hover:border-white/20"
            data-animate
            style={`transition-delay: ${i * 80}ms;`}
          >
            <h3 class="text-base font-semibold">{t(s.title, lang)}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-white/70">{t(s.description, lang)}</p>
          </article>
        ))}
      </div>

      <div class="mt-10" data-animate>
        <a
          href="/leistungen"
          class="inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold bg-white hover:bg-slate-50 text-slate-900 border border-black/10 hover:border-black/20 transition-all duration-300 dark:bg-white/10 dark:text-white dark:hover:bg-white/15 dark:border-white/10 dark:hover:border-white/20"
        >
          Alle Behandlungen ansehen
          <i data-lucide="arrow-right" class="ml-2 h-4 w-4" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </section>
)}

