---
import { config, t } from '../../utils/config';

export interface Props {
  lang: string;
  index: number;
  total: number;
  viewport: 'mobile' | 'desktop';
}

const { lang, viewport } = Astro.props;

const ui = {
  heading: {
    de: 'Team',
    fr: 'Équipe',
    it: 'Team',
    en: 'Team',
  } as Record<string, string>,
  subtitle: {
    de: `Die Menschen hinter ${config.business.name}`,
    fr: `Les personnes derrière ${config.business.name}`,
    it: `Le persone dietro ${config.business.name}`,
    en: `The people behind ${config.business.name}`,
  } as Record<string, string>,
};

const members = config.team.members ?? [];
const count = members.length;

function isDoctor(memberName: string) {
  return memberName.toLowerCase().includes('roman') && memberName.toLowerCase().includes('obrenovic');
}

function desktopGridClass() {
  if (count <= 1) return 'md:grid-cols-1 max-w-sm';
  if (count === 2) return 'md:grid-cols-2 max-w-2xl';
  if (count === 3) return 'md:grid-cols-3';
  if (count === 4) return 'md:grid-cols-4';
  return 'md:grid-cols-3';
}

function webpSrcSet(src: string, widths: number[]) {
  const base = src.replace(/\.(jpg|png)$/, '');
  return widths.map((w) => `${base}-${w}.webp ${w}w`).join(', ');
}
---

{viewport === 'mobile' ? (
  <section class="min-h-[100dvh] w-full bg-white/60 dark:bg-neutral-900 px-6 py-12 flex items-start">
    <div class="w-full mx-auto max-w-sm">
      <div class="space-y-3" data-animate>
        {members.map((m) => (
          <article class="relative rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 px-4 py-3">
            <div class="flex flex-col items-center text-center">
              {isDoctor(m.name) ? (
                <a href="/dr-roman-obrenovic" class="relative block w-full pb-10">
                  <div class="relative">
                    <picture>
                      <source
                        type="image/webp"
                        srcset={webpSrcSet(m.image, [240, 480])}
                        sizes="(max-width: 768px) 176px, 240px"
                      />
                      <img
                        src={m.image}
                        alt={`${m.name} – ${t(m.role, lang)}`}
                        class="h-44 w-44 mx-auto rounded-3xl object-cover"
                        width="240"
                        height="240"
                        loading="lazy"
                        decoding="async"
                      />
                    </picture>
                  </div>
                  <div class="mt-2 w-full min-w-0">
                    <div class="text-base font-semibold leading-tight">{m.name}</div>
                    <div class="mt-1 text-sm leading-snug text-slate-600 dark:text-white/60">{t(m.role, lang)}</div>
                  </div>
                  <span
                    class="btn-primary absolute bottom-0 right-0 rounded-full px-3 py-1 text-xs font-semibold text-white shadow-sm"
                  >
                    CV
                  </span>
                </a>
              ) : (
                <>
                  <div class="relative">
                    <picture>
                      <source
                        type="image/webp"
                        srcset={webpSrcSet(m.image, [240, 480])}
                        sizes="(max-width: 768px) 176px, 240px"
                      />
                      <img
                        src={m.image}
                        alt={`${m.name} – ${t(m.role, lang)}`}
                        class="h-44 w-44 mx-auto rounded-3xl object-cover"
                        width="240"
                        height="240"
                        loading="lazy"
                        decoding="async"
                      />
                    </picture>
                  </div>
                  <div class="mt-2 w-full min-w-0">
                    <div class="text-base font-semibold leading-tight">{m.name}</div>
                    <div class="mt-1 text-sm leading-snug text-slate-600 dark:text-white/60">{t(m.role, lang)}</div>
                  </div>
                </>
              )}
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
) : (
  <section class="w-full py-20 bg-white/60 dark:bg-neutral-900">
    <div class="mx-auto max-w-6xl px-8">
      <div class="text-center">
        <h2 class="text-4xl font-bold tracking-tight" data-animate>
          {ui.heading[lang] ?? ui.heading.en}
        </h2>
        <p class="mt-3 text-slate-600 dark:text-white/60" data-animate>
          {ui.subtitle[lang] ?? ui.subtitle.en}
        </p>
      </div>

      <div class={`mx-auto mt-12 grid grid-cols-1 gap-6 ${desktopGridClass()}`}>
        {members.map((m, i) => (
          <article data-animate style={`transition-delay: ${i * 80}ms;`}>
            {isDoctor(m.name) ? (
              <a
                href="/dr-roman-obrenovic"
                class="group relative block overflow-hidden rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:bg-slate-50 hover:border-black/20 dark:hover:bg-white/10 dark:hover:border-white/20"
                aria-label="CV von Dr. Roman Obrenovic ansehen"
              >
                <div class="relative overflow-hidden">
                  <picture>
                    <source type="image/webp" srcset={webpSrcSet(m.image, [240, 480])} sizes="(max-width: 768px) 176px, 600px" />
                    <img
                      src={m.image}
                      alt={`${m.name} – ${t(m.role, lang)}`}
                      class="aspect-[3/4] w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      width="600"
                      height="800"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-black/0"></div>
                </div>
                <div class="p-5">
                  <div class="font-semibold">{m.name}</div>
                  <div class="text-sm text-slate-600 dark:text-white/60">{t(m.role, lang)}</div>
                </div>
                <span
                  class="btn-primary absolute bottom-4 right-4 rounded-full px-3 py-1 text-xs font-semibold text-white shadow-sm"
                >
                  CV
                </span>
              </a>
            ) : (
              <div class="group overflow-hidden rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:bg-slate-50 hover:border-black/20 dark:hover:bg-white/10 dark:hover:border-white/20">
                <div class="relative overflow-hidden">
                  <picture>
                    <source type="image/webp" srcset={webpSrcSet(m.image, [240, 480])} sizes="(max-width: 768px) 176px, 600px" />
                    <img
                      src={m.image}
                      alt={`${m.name} – ${t(m.role, lang)}`}
                      class="aspect-[3/4] w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      width="600"
                      height="800"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-black/0"></div>
                </div>
                <div class="p-5">
                  <div class="font-semibold">{m.name}</div>
                  <div class="text-sm text-slate-600 dark:text-white/60">{t(m.role, lang)}</div>
                </div>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
)}

