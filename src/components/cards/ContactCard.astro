---
import { config } from '../../utils/config';

export interface Props {
  lang: string;
  index: number;
  total: number;
  viewport: 'mobile' | 'desktop';
}

const { lang, viewport } = Astro.props;

const ui = {
  heading: {
    de: 'Kontakt',
    fr: 'Contact',
    it: 'Contatto',
    en: 'Contact',
  } as Record<string, string>,
  subtitle: {
    de: 'Schnell erreichbar — telefonisch oder per E‑Mail.',
    fr: 'Joignable rapidement — par téléphone ou e‑mail.',
    it: 'Facilmente raggiungibile — telefono o e‑mail.',
    en: 'Easy to reach — phone or email.',
  } as Record<string, string>,
  call: {
    de: 'Anrufen',
    fr: 'Appeler',
    it: 'Chiama',
    en: 'Call',
  } as Record<string, string>,
  email: {
    de: 'E‑Mail',
    fr: 'E‑mail',
    it: 'E‑mail',
    en: 'Email',
  } as Record<string, string>,
  whatsapp: {
    de: 'WhatsApp',
    fr: 'WhatsApp',
    it: 'WhatsApp',
    en: 'WhatsApp',
  } as Record<string, string>,
  hours: {
    de: 'Öffnungszeiten',
    fr: 'Horaires',
    it: 'Orari',
    en: 'Hours',
  } as Record<string, string>,
  imprint: {
    de: 'Impressum',
    fr: 'Mentions légales',
    it: 'Note legali',
    en: 'Imprint',
  } as Record<string, string>,
  privacy: {
    de: 'Datenschutz',
    fr: 'Protection des données',
    it: 'Privacy',
    en: 'Privacy',
  } as Record<string, string>,
  lage: {
    de: 'So finden Sie uns',
    fr: 'Comment nous trouver',
    it: 'Come trovarci',
    en: 'How to find us',
  } as Record<string, string>,
};

const whatsappHref = config.contact.whatsapp
  ? `https://wa.me/${config.contact.whatsapp.replace(/\+/g, '')}`
  : null;

function buildMailtoHref() {
  const subject = config.cta.email?.subject?.[lang] || config.cta.email?.subject?.[config.i18n.default] || 'Terminanfrage';
  const body = config.cta.email?.body?.[lang] || config.cta.email?.body?.[config.i18n.default] || '';
  const qs = `subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  return `mailto:${config.contact.email}?${qs}`;
}
const mailtoHref = buildMailtoHref();
const appointmentLabel = config.cta.primary[lang] ?? config.cta.primary[config.i18n.default] ?? 'Termin anfragen';

const imprintHref = lang === 'fr' ? '/fr/impressum' : lang === 'it' ? '/it/impressum' : lang === 'en' ? '/en/impressum' : '/impressum';
const privacyHref = lang === 'fr' ? '/fr/datenschutz' : lang === 'it' ? '/it/datenschutz' : lang === 'en' ? '/en/datenschutz' : '/datenschutz';
const mapsHref = `https://www.google.com/maps?q=${encodeURIComponent(
  `${config.location.street}, ${config.location.zip} ${config.location.city}`
)}`;

const appointmentNote = (config as any).appointment_note ? (config as any).appointment_note[lang] || (config as any).appointment_note[config.i18n.default] : null;
---

{viewport === 'mobile' ? (
  <section class="min-h-[100dvh] w-full bg-white/60 dark:bg-neutral-900 px-6 py-12 flex items-center">
    <div class="w-full mx-auto max-w-sm">
      <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight" data-animate>
        {ui.heading[lang] ?? ui.heading.en}
      </h2>
      <p class="mt-3 text-slate-600 dark:text-white/60" data-animate>
        {ui.subtitle[lang] ?? ui.subtitle.en}
      </p>
      </div>

    <div class="mt-8 text-center" data-animate>
      <a
        href={mapsHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex flex-col items-center gap-1.5 rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 px-5 py-4 hover:bg-slate-50 hover:border-black/20 transition-colors dark:hover:bg-white/10 dark:hover:border-white/20"
      >
        <div class="text-base font-semibold text-slate-900 dark:text-white/90">
          {config.business.name}
        </div>
        <div class="text-base font-semibold text-slate-900 dark:text-white/90">
          {config.location.street}
        </div>
        <div class="text-base font-semibold text-slate-900 dark:text-white/90">
          {config.location.zip}{' '}{config.location.city}
        </div>
        <div class="mt-1 text-xs text-slate-500 dark:text-white/50">
          Google Maps öffnen
        </div>
      </a>

      <div class="mt-4" data-animate>
        <a
          href="/lage"
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-slate-800 hover:text-slate-950 dark:text-white/80 dark:hover:text-white"
        >
          <i data-lucide="map" class="h-4 w-4" aria-hidden="true"></i>
          {ui.lage[lang] ?? ui.lage.de}
          <i data-lucide="chevron-right" class="h-4 w-4 opacity-60" aria-hidden="true"></i>
        </a>
      </div>

      <div class="mt-4 space-y-2">
        <div>
          <a class="text-base font-medium text-slate-700 hover:text-slate-900 dark:text-white/70 dark:hover:text-white" href={`tel:${config.contact.phone}`}>
            {config.contact.phone_display}
          </a>
        </div>
        <div>
          <a class="text-base font-medium text-slate-700 hover:text-slate-900 dark:text-white/70 dark:hover:text-white" href={`mailto:${config.contact.email}`}>
            {config.contact.email}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3" data-animate>
      <a
        class="btn-primary inline-flex items-center justify-center gap-2 rounded-2xl px-4 py-3 text-center text-sm font-semibold text-white shadow-sm"
        href={`tel:${config.contact.phone}`}
      >
        <i data-lucide="phone" class="h-4 w-4" aria-hidden="true"></i>
        {ui.call[lang] ?? ui.call.en}
      </a>
      {whatsappHref ? (
        <a class="inline-flex items-center justify-center gap-2 rounded-2xl px-4 py-3 text-center text-sm font-semibold text-slate-900 bg-white border border-black/10 dark:text-white dark:bg-white/10 dark:border-white/10" href={`mailto:${config.contact.email}`}>
          <i data-lucide="mail" class="h-4 w-4" aria-hidden="true"></i>
          {ui.email[lang] ?? ui.email.en}
        </a>
      ) : (
        <a class="inline-flex items-center justify-center gap-2 rounded-2xl px-4 py-3 text-center text-sm font-semibold text-slate-900 bg-white border border-black/10 dark:text-white dark:bg-white/10 dark:border-white/10" href={`mailto:${config.contact.email}`}>
          <i data-lucide="mail" class="h-4 w-4" aria-hidden="true"></i>
          {ui.email[lang] ?? ui.email.en}
        </a>
      )}
    </div>

    <div class="mt-8" data-animate>
      <iframe
        src={config.location.google_maps_embed}
        title={`${config.business.name} – Google Maps`}
        class="h-40 w-full rounded-2xl border border-black/10 dark:border-white/10"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <div class="mt-5 flex items-center justify-center gap-4 text-xs text-slate-500 dark:text-white/50" data-animate>
      <a class="hover:text-slate-800 dark:hover:text-white/80" href={imprintHref}>
        {ui.imprint[lang] ?? ui.imprint.en}
      </a>
      <span aria-hidden="true">•</span>
      <a class="hover:text-slate-800 dark:hover:text-white/80" href={privacyHref}>
        {ui.privacy[lang] ?? ui.privacy.en}
      </a>
    </div>

    </div>
  </section>
) : (
  <section class="w-full py-20 bg-white/60 dark:bg-neutral-900">
    <div class="mx-auto max-w-6xl px-8">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-2 items-stretch">
        <div>
          <h2 class="text-4xl font-bold tracking-tight" data-animate>
            {ui.heading[lang] ?? ui.heading.en}
          </h2>
          <p class="mt-3 text-slate-600 dark:text-white/60" data-animate>
            {ui.subtitle[lang] ?? ui.subtitle.en}
          </p>

          <div class="mt-10 space-y-4" data-animate>
            <div class="flex items-start gap-3 rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-5">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-black/5 dark:bg-white/10">📍</div>
              <a
                href={mapsHref}
                target="_blank"
                rel="noopener noreferrer"
                class="block hover:text-slate-900 dark:hover:text-white"
                aria-label={`Google Maps: ${config.business.name}, ${config.location.street}, ${config.location.zip} ${config.location.city}`}
              >
                <div class="text-lg font-semibold leading-tight text-slate-900 dark:text-white/90">
                  {config.business.name}
                </div>
                <div class="mt-1 text-lg font-semibold leading-tight text-slate-900 dark:text-white/90">
                  {config.location.street}
                </div>
                <div class="mt-1 text-lg font-semibold leading-tight text-slate-900 dark:text-white/90">
                  {config.location.zip}{' '}{config.location.city}
                </div>
                <div class="mt-2 text-sm text-slate-500 dark:text-white/50">
                  Google Maps öffnen
                </div>
              </a>
            </div>

            <div class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-5" data-animate>
              <a
                href="/lage"
                class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900 hover:text-slate-950 dark:text-white/85 dark:hover:text-white"
              >
                <i data-lucide="map" class="h-4 w-4 shrink-0" aria-hidden="true"></i>
                {ui.lage[lang] ?? ui.lage.de}
                <i data-lucide="chevron-right" class="h-4 w-4 shrink-0 opacity-60" aria-hidden="true"></i>
              </a>
            </div>

            <div class="flex items-start gap-3 rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-5">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-black/5 dark:bg-white/10">📞</div>
              <div class="flex min-h-10 flex-1 items-center justify-start">
                <a class="text-lg font-semibold text-slate-900 hover:text-slate-950 dark:text-white/80 dark:hover:text-white" href={`tel:${config.contact.phone}`}>
                  {config.contact.phone_display}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-3 rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-5">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-black/5 dark:bg-white/10">✉️</div>
              <div class="flex min-h-10 flex-1 items-center justify-start">
                <a class="text-lg font-semibold text-slate-900 hover:text-slate-950 dark:text-white/80 dark:hover:text-white" href={`mailto:${config.contact.email}`}>
                  {config.contact.email}
                </a>
              </div>
            </div>
          </div>

          <div class="mt-10 rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6" data-animate>
            <div class="font-semibold">{ui.hours[lang] ?? ui.hours.en}</div>
            {appointmentNote ? (
              <div class="mt-2 text-sm text-slate-600 dark:text-white/60">
                {appointmentNote}
              </div>
            ) : null}
            <div class="mt-4 divide-y divide-black/10 dark:divide-white/10">
              {config.hours.map((h) => (
                <div class="flex items-center justify-between py-3 text-sm">
                  <span class="text-slate-600 dark:text-white/70">{h.days}</span>
                  <span class:list={['font-medium', h.time.toLowerCase().includes('geschlossen') ? 'text-red-500/70 dark:text-red-400/60' : 'text-slate-800 dark:text-white/80']}>
                    {h.time}
                  </span>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-3" data-animate>
            <a
              class="btn-primary inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white"
              href={mailtoHref}
            >
              <i data-lucide="mail" class="h-4 w-4" aria-hidden="true"></i>
              {appointmentLabel}
            </a>
            <a
              class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold bg-white hover:bg-slate-50 text-slate-900 border border-black/10 hover:border-black/20 transition-all duration-300 dark:bg-white/10 dark:text-white dark:hover:bg-white/15 dark:border-white/10 dark:hover:border-white/20"
              href={`tel:${config.contact.phone}`}
            >
              <i data-lucide="phone" class="h-4 w-4" aria-hidden="true"></i>
              {ui.call[lang] ?? ui.call.en}
            </a>
            {whatsappHref ? (
              <a class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white bg-green-600" href={whatsappHref}>
                {ui.whatsapp[lang] ?? ui.whatsapp.en}
              </a>
            ) : null}
          </div>
        </div>

        <div class="flex flex-col items-center justify-center self-center" data-animate>
          <iframe
            src={config.location.google_maps_embed}
            title={`${config.business.name} – Google Maps`}
            class="h-[500px] w-full rounded-3xl border border-black/10 dark:border-white/10"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>

          <div class="mt-5 flex items-center justify-center gap-4 text-xs text-slate-500 dark:text-white/50">
            <a class="hover:text-slate-800 dark:hover:text-white/80" href={imprintHref}>
              {ui.imprint[lang] ?? ui.imprint.en}
            </a>
            <span aria-hidden="true">•</span>
            <a class="hover:text-slate-800 dark:hover:text-white/80" href={privacyHref}>
              {ui.privacy[lang] ?? ui.privacy.en}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

