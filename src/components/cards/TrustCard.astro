---
import { config, t } from '../../utils/config';

export interface Props {
  lang: string;
  index: number;
  total: number;
  viewport: 'mobile' | 'desktop';
}

const { lang, viewport } = Astro.props;

const ui = {
  heading: {
    de: `Warum ${config.business.name}?`,
    fr: `Pourquoi ${config.business.name} ?`,
    it: `Perché ${config.business.name}?`,
    en: `Why ${config.business.name}?`,
  } as Record<string, string>,
  badges: {
    de: 'Qualifikationen',
    fr: 'Qualifications',
    it: 'Qualifiche',
    en: 'Qualifications',
  } as Record<string, string>,
  experience: {
    de: '20+ Jahre Erfahrung',
    fr: '20+ ans d’expérience',
    it: '20+ anni di esperienza',
    en: '20+ years of experience',
  } as Record<string, string>,
};

const reasons: Record<string, string>[] = (config.trust as any).reasons ?? [];
const heroOrGallery = '/gallery/practice3.jpg';
const heroOrGalleryAlt =
  (config.gallery?.[2]?.alt ? t(config.gallery[2].alt, lang) : config.business.name) ||
  config.business.name;
---

{viewport === 'mobile' ? (
  <section class="min-h-[100dvh] w-full bg-white/60 dark:bg-neutral-900 px-6 py-12 flex items-center">
    <div class="w-full mx-auto max-w-sm">
      <div class="text-center">
        <h2 class="text-2xl font-bold tracking-tight" data-animate>
          {ui.heading[lang] ?? ui.heading.en}
        </h2>
      </div>

      {reasons.length ? (
        <ul class="mt-8 space-y-3" data-animate>
          {reasons.map((r) => (
            <li class="flex items-start gap-3">
              <span
                class="mt-1.5 h-2 w-2 shrink-0 rounded-full"
                style="background:#fbbc05;"
                aria-hidden="true"
              ></span>
              <span class="text-sm leading-relaxed text-slate-700 dark:text-white/70">
                {t(r, lang)}
              </span>
            </li>
          ))}
        </ul>
      ) : null}

      {config.trust.certifications?.length ? (
        <div class="mt-8" data-animate>
          <div class="text-sm font-semibold">{ui.badges[lang] ?? ui.badges.en}</div>
          <div class="mt-3 flex flex-wrap gap-2">
            {config.trust.certifications.map((c) => (
              <span class="rounded-full bg-black/5 text-slate-800 px-3 py-1 text-xs font-medium dark:bg-white/10 dark:text-white/80">
                {c}
              </span>
            ))}
          </div>
        </div>
      ) : null}

      <div class="mt-8 rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-4" data-animate>
        <div class="text-sm font-semibold text-slate-900 dark:text-white">
          {ui.experience[lang] ?? ui.experience.en}
        </div>
        <div class="mt-1 text-sm text-slate-600 dark:text-white/60">
          Allgemeine & rekonstruktive Zahnmedizin
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="w-full py-20 bg-white/60 dark:bg-neutral-900">
    <div class="mx-auto max-w-6xl px-8">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-2 items-center">
        <div>
          <h2 class="text-4xl font-bold tracking-tight" data-animate>
            {ui.heading[lang] ?? ui.heading.en}
          </h2>

          {reasons.length ? (
            <ul class="mt-10 space-y-4">
              {reasons.map((r, i) => (
                <li
                  class="flex items-start gap-3"
                  data-animate
                  style={`transition-delay: ${i * 60}ms;`}
                >
                  <span
                    class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full"
                    style="background:#fbbc05;"
                    aria-hidden="true"
                  ></span>
                  <span class="text-base leading-relaxed text-slate-700 dark:text-white/70">
                    {t(r, lang)}
                  </span>
                </li>
              ))}
            </ul>
          ) : null}

          <div class="mt-10" data-animate>
            <div class="text-sm font-semibold">{ui.badges[lang] ?? ui.badges.en}</div>
            <div class="mt-3 flex flex-wrap gap-2">
              {config.trust.certifications.map((c) => (
                <span class="rounded-full bg-black/5 text-slate-800 px-3 py-1 text-xs font-medium dark:bg-white/10 dark:text-white/80">
                  {c}
                </span>
              ))}
            </div>
          </div>

          {config.trust.memberships?.length ? (
            <div class="mt-8 flex flex-wrap items-center gap-4" data-animate>
              {config.trust.memberships.map((m) => (
                <img src={m.logo} alt={m.name} class="h-9 w-auto opacity-90" loading="lazy" decoding="async" />
              ))}
            </div>
          ) : null}
        </div>

        <div class="relative" data-animate>
          <div class="overflow-hidden rounded-3xl border border-black/10 dark:border-white/10">
            <img
              src={heroOrGallery}
              alt={heroOrGalleryAlt}
              class="h-[520px] w-full object-cover"
              width="1200"
              height="800"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="absolute bottom-6 left-6 rounded-2xl bg-white/90 border border-black/10 px-5 py-4 text-neutral-900 shadow-xl backdrop-blur-sm">
            <div class="text-sm font-semibold">{ui.experience[lang] ?? ui.experience.en}</div>
            <div class="mt-1 text-sm text-neutral-700">Ruhig. Sorgfältig. Ohne Zeitdruck.</div>
          </div>
        </div>
      </div>
    </div>
  </section>
)}
