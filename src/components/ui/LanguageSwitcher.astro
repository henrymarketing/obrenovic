---
import { config } from '../../utils/config';

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const labels: Record<string, string> = {
  de: 'DE',
  fr: 'FR',
  it: 'IT',
  en: 'EN',
};

if (!config.i18n.available || config.i18n.available.length <= 1) {
  return null;
}
---

<nav
  class="fixed top-4 right-4 z-[60] rounded-full bg-white/70 dark:bg-black/40 backdrop-blur-sm p-1 border border-black/10 dark:border-white/10"
  aria-label="Language"
>
  <ul class="flex items-center gap-1">
    {config.i18n.available.map((l) => {
      const href = l === config.i18n.default ? '/' : `/${l}/`;
      const active = l === lang;
      return (
        <li>
          <a
            href={href}
            class:list={[
              'px-3 py-1.5 rounded-full text-sm font-medium transition-colors duration-300',
              active
                ? 'bg-white text-neutral-900'
                : 'text-neutral-600 hover:text-neutral-900 dark:text-white/60 dark:hover:text-white',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {labels[l] ?? l.toUpperCase()}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

