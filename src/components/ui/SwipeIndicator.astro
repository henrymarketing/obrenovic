---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

const text: Record<string, string> = {
  de: 'Nach oben wischen',
  fr: 'Glissez vers le haut',
  it: 'Scorri verso l’alto',
  en: 'Swipe up',
};
---

<div
  class="absolute bottom-6 left-1/2 -translate-x-1/2 text-center md:hidden animate-bounce-gentle"
  aria-hidden="true"
>
  <div class="text-xs text-slate-600 dark:text-white/60">{text[lang] ?? text.en}</div>
  <svg
    class="mx-auto mt-1 h-5 w-5 text-slate-600 dark:text-white/60"
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M12 5v14m0 0l-6-6m6 6l6-6"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</div>

