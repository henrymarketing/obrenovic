---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config, t } from '../utils/config';

const lang = config.i18n.default;

const title = `Dr. Roman Obrenovic – CV & Hintergrund`;
const description =
  'Dr. med. Dr. med. dent. Roman Obrenovic: Ausbildung und Werdegang (Universität Zürich), rekonstruktive Zahnmedizin und klinische Erfahrung. Praxis in Erlenbach ZH.';

const appointmentNote = t(config.appointment_note ?? { de: 'Termine nach Vereinbarung' }, lang);

function buildMailtoHref() {
  const subject = config.cta.email?.subject?.[lang] || config.cta.email?.subject?.[config.i18n.default] || 'Terminanfrage';
  const body = config.cta.email?.body?.[lang] || config.cta.email?.body?.[config.i18n.default] || '';
  const params = new URLSearchParams({ subject, body });
  return `mailto:${config.contact.email}?${params.toString()}`;
}

const mailHref = buildMailtoHref();
---

<BaseLayout lang={lang} title={title} description={description} canonicalPath="/dr-roman-obrenovic">
  <main id="content" class="min-h-screen px-6 py-16">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-[1fr_360px] items-start">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold tracking-tight">
            Dr. med. Dr. med. dent. Roman Obrenovic
          </h1>
          <p class="mt-3 text-slate-700 dark:text-white/70">
            Doppelter Doktortitel (Medizin & Zahnmedizin) — klinische Ausbildung an der Universität Zürich, mit Schwerpunkt auf rekonstruktiver Zahnmedizin.
          </p>
          <p class="mt-2 text-sm text-slate-600 dark:text-white/60">
            Praxis: {config.location.street}, {config.location.zip} {config.location.city} · {appointmentNote}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              class="btn-primary inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white shadow-sm"
              href={mailHref}
            >
              <i data-lucide="mail" class="h-4 w-4" aria-hidden="true"></i>
              Termin anfragen
            </a>
            <a
              class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold bg-white hover:bg-slate-50 text-slate-900 border border-black/10 hover:border-black/20 transition-all duration-300 dark:bg-white/10 dark:text-white dark:hover:bg-white/15 dark:border-white/10 dark:hover:border-white/20"
              href={`tel:${config.contact.phone}`}
            >
              <i data-lucide="phone" class="h-4 w-4" aria-hidden="true"></i>
              Anrufen
            </a>
          </div>
        </div>

        <aside class="rounded-3xl bg-white border border-black/10 dark:bg-white/6 dark:border-white/10 p-6">
          <img
            src={config.theme.hero_portrait}
            alt="Dr. Roman Obrenovic Portrait"
            class="w-full rounded-2xl object-cover"
            width="720"
            height="900"
            loading="eager"
            decoding="async"
          />
          <div class="mt-5 text-sm text-slate-700 dark:text-white/70">
            <div class="font-semibold text-slate-900 dark:text-white/85">Kontakt</div>
            <div class="mt-2">
              <a class="hover:underline" href={`tel:${config.contact.phone}`}>{config.contact.phone_display}</a><br />
              <a class="hover:underline" href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
            </div>
          </div>
        </aside>
      </div>

      <section class="mt-12 rounded-3xl bg-white border border-black/10 dark:bg-white/6 dark:border-white/10 p-7">
        <h2 class="text-xl font-semibold">Lebenslauf</h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-white/60">
          Auszug aus Ausbildung und beruflicher Tätigkeit.
        </p>

        <div class="mt-8 space-y-10">
          <div>
            <div class="text-sm font-semibold text-slate-900 dark:text-white/85">Berufsausübung Zahnmedizin</div>
            <div class="mt-4 grid grid-cols-1 gap-3">
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">2008 – Ende 2009</div>
                <div class="mt-1 font-medium">Aufnahme der eigenen Praxistätigkeit</div>
              </div>
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">2007</div>
                <div class="mt-1 font-medium">
                  Oberassistent an der Klinik für Kaufunktionsstörungen und abnehmbare Rekonstruktionen, Prof. S. Palla, Universität Zürich
                </div>
              </div>
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">2007</div>
                <div class="mt-1 font-medium">Promotion zum Doktor der Zahnmedizin der Universität Zürich</div>
              </div>
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">2004 – 2007</div>
                <div class="mt-1 font-medium">
                  Assistent und Postgraduate Ausbildung in rekonstruktiver Zahnmedizin an der Universität Zürich
                </div>
              </div>
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">2001 – 2004</div>
                <div class="mt-1 font-medium">Studium der Zahnmedizin, Universität Zürich</div>
              </div>
            </div>
          </div>

          <div>
            <div class="text-sm font-semibold text-slate-900 dark:text-white/85">Studium und Berufsausübung Medizin</div>
            <div class="mt-4 grid grid-cols-1 gap-3">
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">2001</div>
                <div class="mt-1 font-medium">Promotion zum Doktor der Medizin der Universität Zürich</div>
              </div>
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">1998 – 2001</div>
                <div class="mt-1 font-medium">
                  Assistentsarzt Klinik für Viszeral‑ und Transplantationschirurgie, Universität Zürich (Prof. M. Turina, P.-A. Clavien, R. Stocker)
                </div>
              </div>
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">1992 – 1997</div>
                <div class="mt-1 font-medium">Studium der Medizin, Universität Zürich</div>
              </div>
            </div>
          </div>

          <div>
            <div class="text-sm font-semibold text-slate-900 dark:text-white/85">Schule</div>
            <div class="mt-4 grid grid-cols-1 gap-3">
              <div class="rounded-2xl bg-black/5 dark:bg-white/10 p-5">
                <div class="text-xs text-slate-500 dark:text-white/55">1992</div>
                <div class="mt-1 font-medium">Matura Typus A</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="mt-10 flex flex-wrap items-center gap-4 text-sm">
        <a class="hover:underline text-slate-700 dark:text-white/70" href="/">
          ← Zur Startseite
        </a>
        <a class="hover:underline text-slate-700 dark:text-white/70" href="/leistungen">
          Leistungen →
        </a>
        <a class="hover:underline text-slate-700 dark:text-white/70" href="/zahnarzt-zuerich-erlenbach">
          Zahnarzt für Zürich & Erlenbach →
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

