---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../utils/config';

const lang = 'en';
---

<BaseLayout lang={lang} title="Privacy" canonicalPath="/en/datenschutz">
  <main id="content" class="min-h-screen px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight">Privacy</h1>

      <div class="mt-8 space-y-6 text-slate-700 dark:text-white/70">
        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Controller</div>
          <p class="mt-2 text-sm leading-relaxed">
            The controller for data processing on this website is {config.business.name}, {config.location.street},{' '}
            {config.location.zip} {config.location.city}, Switzerland.
          </p>
          <p class="mt-3 text-sm leading-relaxed">
            Contact: <a class="hover:underline" href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Google Maps</div>
          <p class="mt-2 text-sm leading-relaxed">
            The contact section embeds a Google Maps iframe. When loaded, Google may process technical data (e.g. IP
            address). For details, see Google’s privacy information.
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Cookies & Preferences</div>
          <p class="mt-2 text-sm leading-relaxed">
            This website stores local preferences (e.g. theme/text size). Optional analytics cookies can be configured
            in the Control Center.
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
