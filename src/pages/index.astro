---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../utils/config';
import HeroCard from '../components/cards/HeroCard.astro';
import ServicesCard from '../components/cards/ServicesCard.astro';
import TrustCard from '../components/cards/TrustCard.astro';
import TestimonialsCard from '../components/cards/TestimonialsCard.astro';
import TeamCard from '../components/cards/TeamCard.astro';
import FaqCard from '../components/cards/FaqCard.astro';
import ContactCard from '../components/cards/ContactCard.astro';

const lang = config.i18n.default;

const activeCards = (config.cards ?? []).filter((c) => c !== 'team' || config.team.show);
const total = activeCards.length;

const cardMap: Record<string, any> = {
  hero: HeroCard,
  services: ServicesCard,
  trust: TrustCard,
  testimonials: TestimonialsCard,
  team: TeamCard,
  faq: FaqCard,
  contact: ContactCard,
};

const cardLabels: Record<string, string> = {
  hero: 'Start',
  services: 'Behandlungen',
  trust: 'Warum wir',
  testimonials: 'Bewertungen',
  team: 'Team',
  faq: 'FAQ',
  contact: 'Kontakt',
};

function buildMailtoHref() {
  const subject = config.cta.email?.subject?.[lang] || config.cta.email?.subject?.[config.i18n.default] || 'Terminanfrage';
  const body = config.cta.email?.body?.[lang] || config.cta.email?.body?.[config.i18n.default] || '';
  const qs = `subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  return `mailto:${config.contact.email}?${qs}`;
}

function getCtaHref() {
  if (config.cta.action === 'whatsapp' && config.contact.whatsapp) {
    return `https://wa.me/${config.contact.whatsapp.replace(/\+/g, '')}`;
  }
  if (config.cta.action === 'email') return buildMailtoHref();
  if (config.cta.action === 'url' && config.cta.url) return config.cta.url;
  return `tel:${config.contact.phone}`;
}

const floatingHref = getCtaHref();
---
<BaseLayout lang={lang} canonicalPath="/" lockScroll={true}>
  <main id="content" class="md:hidden">
    <div class="swiper swiper-vertical h-[100dvh]" id="mobile-swiper">
      <div class="swiper-wrapper">
        {activeCards.map((name, index) => {
          const Card = cardMap[name];
          return (
            <div class="swiper-slide">
              <Card lang={lang} index={index} total={total} viewport="mobile" />
            </div>
          );
        })}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </main>

  <main class="hidden md:block h-screen overflow-y-auto" id="desktop-scroll">
    {activeCards.map((name, index) => {
      const Card = cardMap[name];
      return (
        <section
          class="min-h-screen flex items-center justify-center"
          data-card={name}
          data-index={index}
        >
          <Card lang={lang} index={index} total={total} viewport="desktop" />
        </section>
      );
    })}

    <div
      id="desktop-dots"
      class="fixed right-6 top-1/2 -translate-y-1/2 z-[55] flex flex-col gap-3"
      aria-label="Section navigation"
    >
      {activeCards.map((name, i) => (
        <button
          class="group relative h-2.5 w-2.5 rounded-full bg-black/20 hover:bg-black/40 dark:bg-white/20 dark:hover:bg-white/40 transition-colors duration-300"
          data-dot={i}
          aria-label={cardLabels[name] || name}
          type="button"
        >
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 whitespace-nowrap rounded-full bg-white/80 text-slate-900 border border-black/10 dark:bg-black/50 dark:text-white/80 dark:border-white/10 px-3 py-1 text-xs opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            {cardLabels[name] || name}
          </span>
        </button>
      ))}
    </div>
  </main>

  <a
    id="floating-cta"
    href={floatingHref}
    class="btn-primary hidden md:inline-flex items-center gap-2 fixed bottom-6 left-1/2 -translate-x-1/2 z-[55] rounded-full px-6 py-3 text-sm font-semibold text-white opacity-0 translate-y-4 pointer-events-none transition-all duration-300 shadow-lg shadow-black/10"
  >
    <i data-lucide="mail" class="h-4 w-4" aria-hidden="true"></i>
    {config.cta.primary[lang] ?? config.cta.primary[config.i18n.default]}
  </a>

  <script>
    import Swiper from 'swiper';
    import { Pagination, Mousewheel, Keyboard, A11y } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/pagination';

    function triggerAnimations(root) {
      if (!root) return;
      const nodes = root.querySelectorAll('[data-animate]');
      nodes.forEach((n, i) => {
        n.style.transitionDelay = `${Math.min(i * 50, 200)}ms`;
        n.classList.add('animate-in');
      });
    }

    function handleCardVisibility(activeIndex, totalSlides) {
      const cta = document.getElementById('floating-cta');
      if (!cta) return;
      const show = activeIndex >= 1 && activeIndex <= totalSlides - 2;
      cta.classList.toggle('opacity-0', !show);
      cta.classList.toggle('translate-y-4', !show);
      cta.classList.toggle('pointer-events-none', !show);
    }

    function setActiveDot(index) {
      const dots = document.querySelectorAll('[data-dot]');
      dots.forEach((d) => d.classList.remove('bg-white'));
      const active = document.querySelector(`[data-dot=\"${index}\"]`);
      if (active) active.classList.add('bg-white');
    }

    const mqDesktop = window.matchMedia('(min-width: 768px)');
    let mobileSwiper = null;
    let desktopInitialized = false;

    function initMobileSwiper() {
      const el = document.getElementById('mobile-swiper');
      if (!el || mobileSwiper) return;

      const enableWheel = window.matchMedia && window.matchMedia('(pointer:fine)').matches;
      mobileSwiper = new Swiper(el, {
        modules: [Pagination, Mousewheel, Keyboard, A11y],
        direction: 'vertical',
        mousewheel: enableWheel ? { forceToAxis: true, releaseOnEdges: true } : false,
        keyboard: { enabled: true },
        // Make slide changes feel less "twitchy" on small swipes.
        threshold: 32,
        touchAngle: 45,
        longSwipesRatio: 0.35,
        longSwipes: false,
        preventInteractionOnTransition: true,
        speed: 420,
        touchStartPreventDefault: false,
        touchMoveStopPropagation: false,
        touchReleaseOnEdges: true,
        resistanceRatio: 0.85,
        pagination: { el: '.swiper-pagination', clickable: true },
      });

      triggerAnimations(el.querySelector('.swiper-slide-active'));
      handleCardVisibility(0, mobileSwiper.slides.length);

      mobileSwiper.on('slideChange', () => {
        if (!mobileSwiper) return;
        handleCardVisibility(mobileSwiper.activeIndex, mobileSwiper.slides.length);
        triggerAnimations(mobileSwiper.slides[mobileSwiper.activeIndex]);
      });
    }

    function destroyMobileSwiper() {
      if (!mobileSwiper) return;
      mobileSwiper.destroy(true, true);
      mobileSwiper = null;
    }

    function initDesktopScroll() {
      if (desktopInitialized) return;
      const root = document.getElementById('desktop-scroll');
      const sections = root ? Array.from(root.querySelectorAll('section[data-index]')) : [];
      if (!root || !sections.length) return;

      desktopInitialized = true;

      setActiveDot(0);
      handleCardVisibility(0, sections.length);
      triggerAnimations(sections[0]);
      sections.forEach((s) => s.removeAttribute('data-active'));
      sections[0]?.setAttribute('data-active', '1');

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const idx = Number(entry.target.getAttribute('data-index') || '0');
            setActiveDot(idx);
            handleCardVisibility(idx, sections.length);
            triggerAnimations(entry.target);
            sections.forEach((s) => s.removeAttribute('data-active'));
            entry.target.setAttribute('data-active', '1');
          });
        },
        { root, threshold: 0.5 }
      );
      sections.forEach((s) => io.observe(s));

      document.querySelectorAll('[data-dot]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const idx = Number(btn.getAttribute('data-dot') || '0');
          const target = root.querySelector(`section[data-index=\"${idx}\"]`);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      const scrollNext = document.querySelector('[data-scroll-next]');
      if (scrollNext) {
        scrollNext.addEventListener('click', () => {
          const current = root.querySelector('section[data-index][data-active=\"1\"]');
          const currentIdx = current ? Number(current.getAttribute('data-index') || '0') : 0;
          const nextIdx = Math.min(currentIdx + 1, sections.length - 1);
          const target = root.querySelector(`section[data-index=\"${nextIdx}\"]`);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    }

    function syncLayoutMode() {
      if (mqDesktop.matches) {
        destroyMobileSwiper();
        initDesktopScroll();
      } else {
        initMobileSwiper();
      }
    }

    syncLayoutMode();
    mqDesktop.addEventListener('change', syncLayoutMode);
  </script>
</BaseLayout>
