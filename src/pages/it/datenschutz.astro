---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../utils/config';

const lang = 'it';
---

<BaseLayout lang={lang} title="Privacy" canonicalPath="/it/datenschutz">
  <main id="content" class="min-h-screen px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight">Privacy</h1>

      <div class="mt-8 space-y-6 text-slate-700 dark:text-white/70">
        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Titolare del trattamento</div>
          <p class="mt-2 text-sm leading-relaxed">
            Il titolare del trattamento dei dati su questo sito è {config.business.name}, {config.location.street},{' '}
            {config.location.zip} {config.location.city}, Svizzera.
          </p>
          <p class="mt-3 text-sm leading-relaxed">
            Contatto: <a class="hover:underline" href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Google Maps</div>
          <p class="mt-2 text-sm leading-relaxed">
            Nella sezione contatti è incorporata una mappa Google Maps. Durante il caricamento, Google può trattare
            dati tecnici (ad es. indirizzo IP). Per i dettagli, consultare le informazioni sulla privacy di Google.
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Cookie & preferenze</div>
          <p class="mt-2 text-sm leading-relaxed">
            Questo sito salva preferenze locali (tema / dimensione testo). I cookie analytics opzionali possono essere
            configurati nel Control Center.
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
