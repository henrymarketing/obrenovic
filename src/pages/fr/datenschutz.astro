---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../utils/config';

const lang = 'fr';
---

<BaseLayout lang={lang} title="Protection des données" canonicalPath="/fr/datenschutz">
  <main id="content" class="min-h-screen px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight">Protection des données</h1>

      <div class="mt-8 space-y-6 text-slate-700 dark:text-white/70">
        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Responsable</div>
          <p class="mt-2 text-sm leading-relaxed">
            Le responsable du traitement des données sur ce site est {config.business.name}, {config.location.street},{' '}
            {config.location.zip} {config.location.city}, Suisse.
          </p>
          <p class="mt-3 text-sm leading-relaxed">
            Contact : <a class="hover:underline" href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Google Maps</div>
          <p class="mt-2 text-sm leading-relaxed">
            La section de contact intègre une carte Google Maps. Lors du chargement, Google peut traiter des données
            techniques (p. ex. adresse IP). Pour plus de détails, veuillez consulter les informations de Google.
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Cookies & préférences</div>
          <p class="mt-2 text-sm leading-relaxed">
            Ce site enregistre des préférences locales (thème / taille de texte). Les cookies d’analytics optionnels
            peuvent être configurés dans le Control Center.
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
