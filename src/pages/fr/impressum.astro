---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../utils/config';

const lang = 'fr';
---

<BaseLayout lang={lang} title="Mentions légales" canonicalPath="/fr/impressum">
  <main id="content" class="min-h-screen px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight">Mentions légales</h1>

      <div class="mt-8 space-y-6 text-slate-700 dark:text-white/70">
        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">{config.business.name}</div>
          <div class="mt-2">
            {config.location.street}<br />
            {config.location.zip} {config.location.city}<br />
            Suisse
          </div>
          <div class="mt-4">
            <a class="hover:underline" href={`tel:${config.contact.phone}`}>{config.contact.phone_display}</a><br />
            <a class="hover:underline" href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
          </div>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Responsabilité</div>
          <p class="mt-2 text-sm leading-relaxed">
            Les contenus de ce site sont élaborés avec soin, sans garantie quant à leur exactitude, exhaustivité ou
            actualité.
          </p>
          <p class="mt-3 text-sm leading-relaxed">
            Nous n’assumons aucune responsabilité pour les contenus de liens externes. Les opérateurs des pages liées
            sont seuls responsables de leur contenu.
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
