---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../utils/config';

const lang = config.i18n.default;
---

<BaseLayout lang={lang} title="Datenschutz" canonicalPath="/datenschutz">
  <main id="content" class="min-h-screen px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight">Datenschutz</h1>

      <div class="mt-8 space-y-6 text-slate-700 dark:text-white/70">
        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Verantwortliche Stelle</div>
          <p class="mt-2 text-sm leading-relaxed">
            Verantwortlich für die Datenverarbeitung auf dieser Website ist {config.business.name}, {config.location.street},{' '}
            {config.location.zip} {config.location.city}, Schweiz.
          </p>
          <p class="mt-3 text-sm leading-relaxed">
            Kontakt: <a class="hover:underline" href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Google Maps</div>
          <p class="mt-2 text-sm leading-relaxed">
            Auf der Kontaktseite ist eine Karte von Google Maps eingebunden. Beim Aufruf kann Google technische Daten
            (z. B. IP-Adresse) verarbeiten. Details finden Sie in den Datenschutzhinweisen von Google.
          </p>
        </section>

        <section class="rounded-2xl bg-white border border-black/10 dark:bg-white/5 dark:border-white/10 p-6">
          <div class="font-semibold text-slate-900 dark:text-white">Cookies & Einstellungen</div>
          <p class="mt-2 text-sm leading-relaxed">
            Diese Website nutzt lokale Speichereinstellungen (z. B. für Theme/Textgrösse). Optionale Analytics-Cookies
            können Sie im Control Center konfigurieren.
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
